    {
      "parameters": {
        "jsCode": "const item = $json;\n\nconst weekId = item.week_id || item.week_id_2 || '';\nconst theme = item.theme || '';\nconst trendSummary = item.trend_summary || '';\nconst assetRequestMessage = item.asset_request_message || '';\nconst assets = item.assets || [];\n\nconst weeklyPlan = {\n  week_id: weekId,\n  theme,\n  trend_summary: trendSummary,\n  asset_request_message: assetRequestMessage\n};\n\nconst assetList = assets.map((a, index) => ({\n  asset_id: a.asset_id,\n  asset_type: a.asset_type,\n  file_url: a.file_url,\n  file_name: a.file_name || `asset_${index + 1}`\n}));\n\nconst prompt = `\nYou are the content engine for a niche underground electronic DJ brand.\n\nYour job is to generate 3 social media posts that feel authentic, distinctive, and aligned with the artist identity.\n\nARTIST PROFILE:\nStyle: Groovy, emotional electronic music with strong identity\nGenres: House / Electronic with balearic influence, minimal, deep, indie dance touches\nTone: Energetic, emotional, minimal, mysterious, elegant, slightly ironic\nVisual identity: Red, black, cream; club, minimal setups, urban night\nAudience: 20–35, club-oriented, underground, taste-driven\n\nANTI-PATTERNS (STRICT):\n- generic DJ captions (\"what a night\", \"crazy energy\", etc.)\n- influencer tone\n- fake hype\n- over-explaining\n- emojis overload\n- mainstream or commercial vibe\n\nWEEKLY PLAN:\n${JSON.stringify(weeklyPlan, null, 2)}\n\nAVAILABLE ASSETS:\n${JSON.stringify(assetList, null, 2)}\n\nRULES:\n- English only\n- Generate exactly 3 posts\n- Each post must feel unique and intentional\n- Keep captions concise and evocative\n- Avoid clichés completely\n- Do NOT invent facts (events, crowds, locations, etc.)\n- Do NOT mention visual editing\n- Stay grounded in authenticity\n- Subtle irony is allowed but must be minimal\n- Hashtags must be relevant, not spammy\n\nOUTPUT FORMAT (STRICT JSON):\n{\n  \"posts\": [\n    {\n      \"post_number\": 1,\n      \"content_type\": \"string\",\n      \"asset_ids\": [\"id1\", \"id2\"],\n      \"instagram_caption\": \"string\",\n      \"instagram_short_caption\": \"string\",\n      \"tiktok_caption\": \"string\",\n      \"hashtags\": [\"tag1\", \"tag2\", \"tag3\"],\n      \"posting_recommendation\": {\n        \"day\": \"string\",\n        \"time_window\": \"string\"\n      },\n      \"rationale\": \"short explanation of why this works\"\n    },\n    {\n      \"post_number\": 2,\n      \"content_type\": \"string\",\n      \"asset_ids\": [\"id1\"],\n      \"instagram_caption\": \"string\",\n      \"instagram_short_caption\": \"string\",\n      \"tiktok_caption\": \"string\",\n      \"hashtags\": [\"tag1\", \"tag2\", \"tag3\"],\n      \"posting_recommendation\": {\n        \"day\": \"string\",\n        \"time_window\": \"string\"\n      },\n      \"rationale\": \"short explanation of why this works\"\n    },\n    {\n      \"post_number\": 3,\n      \"content_type\": \"string\",\n      \"asset_ids\": [\"id1\"],\n      \"instagram_caption\": \"string\",\n      \"instagram_short_caption\": \"string\",\n      \"tiktok_caption\": \"string\",\n      \"hashtags\": [\"tag1\", \"tag2\", \"tag3\"],\n      \"posting_recommendation\": {\n        \"day\": \"string\",\n        \"time_window\": \"string\"\n      },\n      \"rationale\": \"short explanation of why this works\"\n    }\n  ]\n}\n\nIMPORTANT:\n- Return ONLY valid JSON\n- No markdown\n- No explanations\n`;\n\nreturn [\n  {\n    json: {\n      week_id: weekId,\n      prompt\n    }\n  }\n];"
      },
