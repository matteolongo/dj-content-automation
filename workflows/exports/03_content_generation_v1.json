    {
      "parameters": {
        "jsCode": "const targetWeekId = $('Set week_id').first().json.week_id;\nconst items = $input.all();\nconsole.log(targetWeekId);\nconst assets = items\n  .map(item => item.json)\n  .filter(row => row.week_id == targetWeekId);\n\nif (assets.length === 0) {\n  throw new Error(`No assets found for week_id=${targetWeekId}`);\n}\n\nreturn [\n  {\n    json: {\n      week_id: targetWeekId,\n      assets\n    }\n  }\n];"
      },
