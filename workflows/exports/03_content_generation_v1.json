    {
      "parameters": {
        "jsCode": "let response = $json;\n\nlet text = null;\n\nif (response.output && Array.isArray(response.output)) {\n  for (const item of response.output) {\n    if (item.content && Array.isArray(item.content)) {\n      for (const content of item.content) {\n        if (content.type === 'output_text' && content.text) {\n          text = content.text;\n          break;\n        }\n      }\n    }\n    if (text) break;\n  }\n}\n\nif (!text) {\n  throw new Error('Could not find output text in OpenAI response');\n}\n\ntext = text.trim();\n\nlet parsed;\ntry {\n  parsed = JSON.parse(text);\n} catch (err) {\n  throw new Error(`Failed to parse content generation JSON: ${err.message}\\nRaw text:\\n${text}`);\n}\n\nconst weekId = $('Build content prompt').first().json.week_id;\nconst posts = parsed.posts || [];\n\nif (!Array.isArray(posts) || posts.length === 0) {\n  throw new Error('No posts returned by model');\n}\n\nreturn posts.map((post, index) => ({\n  json: {\n    draft_id: `${weekId}-post-${post.post_number || index + 1}`,\n    week_id: weekId,\n    post_number: post.post_number || index + 1,\n    content_type: post.content_type || '',\n    caption: post.instagram_caption || '',\n    hashtags: Array.isArray(post.hashtags) ? post.hashtags.join(', ') : '',\n    asset_ids: Array.isArray(post.asset_ids) ? post.asset_ids.join(', ') : '',\n    approval_status: 'pending'\n  }\n}));"
      },
